---
import BaseLayout from "./BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  publishDate?: Date;
  lastUpdated?: Date;
}

const { title, description, ogImage, noindex, publishDate, lastUpdated } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  noindex={noindex}
  publishDate={publishDate}
  lastUpdated={lastUpdated}
>
  <slot name="head" slot="head" />
  <Nav />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</BaseLayout>
