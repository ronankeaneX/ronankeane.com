---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  publishDate?: Date;
  lastUpdated?: Date;
}

const {
  title,
  description,
  ogImage = "/images/ronan-keane-og.jpg",
  noindex = false,
  publishDate,
  lastUpdated,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ga4Id = import.meta.env.PUBLIC_GA4_ID;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:type"        content="website" />
    <meta property="og:image"       content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name"   content="Ronan Keane" />

    <!-- Twitter / X -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={new URL(ogImage, Astro.site).toString()} />

    {publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}
    {lastUpdated  && <meta property="article:modified_time"  content={lastUpdated.toISOString()}  />}

    <!-- JSON-LD schema injected per-page via named slot -->
    <slot name="head" />

    <!-- GA4 — active only when PUBLIC_GA4_ID env var is set -->
    {ga4Id && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script is:inline define:vars={{ ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag("js", new Date());
          gtag("config", ga4Id);
        </script>
      </>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
