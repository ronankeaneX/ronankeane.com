---
const year = new Date().getFullYear();
---

<footer class="border-t border-rule mt-24">
  <div class="max-w-6xl mx-auto px-6 md:px-12 py-12">
    <div class="flex flex-col md:flex-row justify-between gap-8">
      <div>
        <a href="/" class="font-display text-lg font-semibold text-ink">
          Ronan Keane<span class="text-accent">.</span>
        </a>
        <p class="font-mono text-xs text-ink-subtle mt-2 uppercase tracking-widest">
          AI Strategy &amp; Implementation
        </p>
      </div>
      <nav class="flex flex-wrap gap-x-8 gap-y-3 font-mono text-xs uppercase tracking-widest text-ink-muted" aria-label="Footer navigation">
        <a href="/framework/" class="hover:text-accent transition-colors">Framework</a>
        <a href="/services/" class="hover:text-accent transition-colors">Services</a>
        <a href="/case-studies/" class="hover:text-accent transition-colors">Case Studies</a>
        <a href="/blog/" class="hover:text-accent transition-colors">Blog</a>
        <a href="/contact/" class="hover:text-accent transition-colors">Contact</a>
      </nav>
    </div>
    <div class="border-t border-rule mt-8 pt-8 flex flex-col md:flex-row justify-between gap-2 font-mono text-xs text-ink-subtle uppercase tracking-widest">
      <span>&copy; {year} Ronan Keane. All rights reserved.</span>
      <span>North Carolina &middot; Serving clients nationally</span>
    </div>
  </div>
</footer>
