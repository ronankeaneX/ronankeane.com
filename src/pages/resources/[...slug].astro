---
import { getCollection, render } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";
import SchemaOrg from "../../components/SchemaOrg.astro";

const CALENDLY = "https://calendly.com/ronankeane/ai-revenue-acceleration-readiness-discovery-call";

export async function getStaticPaths() {
  const entries = await getCollection("resources", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  );
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const {
  title, description, resource_type, gated, file, schema_type, faq,
  publishDate, lastUpdated, noindex,
} = entry.data;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<PageLayout
  title={`${title} — Ronan Keane`}
  description={description}
  noindex={noindex}
  publishDate={publishDate instanceof Date ? publishDate : new Date(String(publishDate))}
  lastUpdated={lastUpdated instanceof Date ? lastUpdated : new Date(String(lastUpdated))}
>
  <SchemaOrg
    slot="head"
    url={canonical}
    title={`${title} — Ronan Keane`}
    description={description}
    schemaTypes={schema_type}
    publishDate={publishDate instanceof Date ? publishDate : new Date(String(publishDate))}
    lastUpdated={lastUpdated instanceof Date ? lastUpdated : new Date(String(lastUpdated))}
    faqItems={faq}
    breadcrumbs={[{ name: title, url: canonical }]}
  />

  <article class="max-w-3xl mx-auto px-6 md:px-12 py-16 md:py-24">

    <!-- Header -->
    <header class="mb-12">
      <span class="font-mono text-xs uppercase tracking-widest bg-bg-alt border border-rule px-3 py-1 rounded-[2px] text-ink-muted inline-block mb-6">
        {resource_type}
      </span>
      <h1 class="font-display text-4xl md:text-5xl font-semibold leading-tight tracking-tight text-ink mb-6">
        {title}
      </h1>
      <p class="text-lg text-ink-muted leading-relaxed max-w-[58ch]">{description}</p>
    </header>

    <!-- Access CTA (above body for gated resources) -->
    {gated && (
      <section class="bg-bg-alt border border-rule rounded-[2px] px-8 py-8 mb-12">
        <p class="font-mono text-xs uppercase tracking-widest text-ink-subtle mb-3">Access this resource</p>
        <p class="text-ink-muted mb-5 max-w-[52ch]">
          Send a quick message and I'll send this directly to your inbox.
        </p>
        <a href="/contact/" class="bg-accent hover:bg-accent-deep text-white px-6 py-3 rounded-[2px] font-medium transition-colors inline-flex items-center gap-2">
          Request access →
        </a>
      </section>
    )}

    <!-- Body -->
    <div class="prose-content">
      <Content />
    </div>

    <!-- Download CTA (below body for free resources with a file) -->
    {!gated && file && (
      <section class="border-t border-rule mt-12 pt-8">
        <a
          href={file}
          download
          class="bg-accent hover:bg-accent-deep text-white px-6 py-3 rounded-[2px] font-medium transition-colors inline-flex items-center gap-2"
        >
          Download {resource_type} →
        </a>
      </section>
    )}

    <!-- CTA -->
    <section class="bg-bg-alt border border-rule rounded-[2px] px-8 py-10 mt-16">
      <p class="font-mono text-xs uppercase tracking-widest text-accent mb-3">/take the next step</p>
      <h2 class="font-display text-2xl font-semibold text-ink mb-3">Want a direct conversation?</h2>
      <p class="text-ink-muted mb-6 max-w-[52ch]">
        Schedule a 20-minute call — no pitch deck, just a direct conversation about your situation.
      </p>
      <div class="flex flex-wrap gap-4 items-center">
        <a
          href={CALENDLY}
          class="bg-accent hover:bg-accent-deep text-white px-6 py-3 rounded-[2px] font-medium transition-colors inline-flex items-center gap-2"
        >
          Schedule a consultation →
        </a>
        <a href="/contact/" class="text-ink hover:text-accent border-b border-ink hover:border-accent px-2 py-3 font-medium transition-colors">
          Send a message
        </a>
      </div>
    </section>

  </article>
</PageLayout>
