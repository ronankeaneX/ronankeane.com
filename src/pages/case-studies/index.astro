---
import { getCollection } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";
import SchemaOrg from "../../components/SchemaOrg.astro";

const canonical = new URL("/case-studies/", Astro.site).toString();

const studies = await getCollection("case-studies", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);

---

<PageLayout
  title="AI Implementation Case Studies — Ronan Keane"
  description="Real results from AI strategy and implementation engagements. $275M revenue influenced, 70% adoption rates, 500 SQLs/month from zero. B2B companies, measurable outcomes."
>
  <SchemaOrg
    slot="head"
    url={canonical}
    title="AI Implementation Case Studies — Ronan Keane"
    description="Real results from AI strategy and implementation engagements. $275M revenue influenced, 70% adoption rates, 500 SQLs/month from zero. B2B companies, measurable outcomes."
    schemaTypes={["WebPage"]}
    breadcrumbs={[{ name: "Case Studies", url: canonical }]}
  />

  <div class="max-w-3xl mx-auto px-6 md:px-12 py-16 md:py-24">

    <header class="mb-14">
      <p class="font-mono text-xs uppercase tracking-widest text-accent mb-4 inline-flex items-center gap-2">
        <span class="w-6 h-px bg-accent"></span>
        /proof
      </p>
      <h1 class="font-display text-4xl md:text-5xl font-semibold leading-tight tracking-tight text-ink mb-6">
        Case Studies
      </h1>
      <p class="text-lg text-ink-muted leading-relaxed max-w-[56ch]">
        Real engagements, real results. Every number here is from an actual client. No projections, no hypotheticals.
      </p>
    </header>

    {studies.length === 0 ? (
      <p class="text-ink-muted">Case studies coming soon.</p>
    ) : (
      <ul class="space-y-8">
        {studies.map((study) => (
          <li>
            <a href={`/case-studies/${study.id}/`} class="group block border border-rule rounded-[2px] px-7 py-8 hover:border-accent transition-colors">
              <p class="font-mono text-xs uppercase tracking-widest text-accent mb-2">
                Case Study &middot; {study.data.client_industry}
              </p>
              <h2 class="font-display text-xl font-semibold text-ink group-hover:text-accent transition-colors mb-2">
                {study.data.title}
              </h2>
              <p class="text-ink-muted text-sm leading-relaxed mb-6 max-w-[58ch]">
                {study.data.description}
              </p>
              {study.data.key_metrics && study.data.key_metrics.length > 0 && (
                <div class="flex flex-wrap gap-6">
                  {study.data.key_metrics.slice(0, 3).map(({ label, value }) => (
                    <div>
                      <p class="font-display text-2xl font-semibold text-accent leading-none mb-1">{value}</p>
                      <p class="font-mono text-[10px] uppercase tracking-widest text-ink-subtle">{label}</p>
                    </div>
                  ))}
                </div>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}

  </div>
</PageLayout>
