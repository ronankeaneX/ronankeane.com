---
import PageLayout from "../layouts/PageLayout.astro";

const CALENDLY = "https://calendly.com/ronankeane/ai-revenue-acceleration-readiness-discovery-call";
---

<PageLayout
  title="Page Not Found — Ronan Keane"
  description="This page doesn't exist. Find what you're looking for below."
  noindex={true}
>
  <div class="max-w-3xl mx-auto px-6 md:px-12 py-24 md:py-32 text-center">
    <p class="font-mono text-xs uppercase tracking-widest text-accent mb-6">404</p>
    <h1 class="font-display text-4xl md:text-5xl font-semibold leading-tight tracking-tight text-ink mb-6">
      This page doesn't exist.
    </h1>
    <p class="text-lg text-ink-muted leading-relaxed max-w-[46ch] mx-auto mb-12">
      The URL may have changed or the page was removed. Try one of these instead.
    </p>

    <nav class="flex flex-wrap gap-3 justify-center mb-16">
      <a href="/" class="font-mono text-xs uppercase tracking-widest border border-rule px-4 py-2 rounded-[2px] text-ink-muted hover:border-accent hover:text-accent transition-colors">
        Home
      </a>
      <a href="/ai-consultant/" class="font-mono text-xs uppercase tracking-widest border border-rule px-4 py-2 rounded-[2px] text-ink-muted hover:border-accent hover:text-accent transition-colors">
        AI Consulting
      </a>
      <a href="/blog/" class="font-mono text-xs uppercase tracking-widest border border-rule px-4 py-2 rounded-[2px] text-ink-muted hover:border-accent hover:text-accent transition-colors">
        Blog
      </a>
      <a href="/contact/" class="font-mono text-xs uppercase tracking-widest border border-rule px-4 py-2 rounded-[2px] text-ink-muted hover:border-accent hover:text-accent transition-colors">
        Contact
      </a>
    </nav>

    <a
      href={CALENDLY}
      class="bg-accent hover:bg-accent-deep text-white px-7 py-4 rounded-[2px] font-medium transition-colors inline-flex items-center gap-2"
    >
      Schedule a consultation →
    </a>
  </div>
</PageLayout>
