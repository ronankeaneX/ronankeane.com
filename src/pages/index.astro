---
import BaseLayout from "../layouts/BaseLayout.astro";

const calendlyUrl =
  "https://calendly.com/ronankeane/ai-revenue-acceleration-readiness-discovery-call";
---

<BaseLayout
  title="Ronan Keane — AI Strategy & Implementation Consultant"
  description="I help SMB and mid-market companies turn stalled AI initiatives into operational advantage. North Carolina-based. PRIME framework for AI implementation."
>
  <nav class="border-b border-rule px-6 md:px-12 py-5 backdrop-blur-md bg-bg/85 sticky top-0 z-50">
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <a href="/" class="font-display text-xl font-semibold tracking-tight text-ink">
        Ronan Keane<span class="text-accent">.</span>
      </a>
      <div class="hidden md:flex items-center gap-8 font-mono text-sm">
        <a href="/framework/" class="lowercase text-ink-muted hover:text-ink transition-colors">framework</a>
        <a href="/services/" class="lowercase text-ink-muted hover:text-ink transition-colors">services</a>
        <a href="/case-studies/" class="lowercase text-ink-muted hover:text-ink transition-colors">case studies</a>
        <a
          href={calendlyUrl}
          class="bg-ink text-bg px-4 py-2 rounded-[2px] text-xs font-medium uppercase tracking-widest hover:bg-accent transition-colors"
        >
          Schedule a call
        </a>
      </div>
    </div>
  </nav>

  <header class="px-6 md:px-12 py-24 md:py-32 max-w-6xl mx-auto">
    <p class="font-mono text-xs uppercase tracking-widest text-accent mb-6 inline-flex items-center gap-2">
      <span class="w-6 h-px bg-accent"></span>
      AI Strategy &amp; Implementation
    </p>

    <h1 class="font-display text-5xl md:text-7xl lg:text-[5.5rem] font-semibold leading-[1.02] tracking-tight max-w-[18ch] mb-8">
      Turning stalled AI initiatives into <span class="text-accent">operational advantage.</span>
    </h1>

    <p class="text-lg md:text-xl text-ink-muted max-w-[56ch] mb-10 leading-relaxed">
      I help SMB and mid-market companies move from AI research to AI implementation. Twenty years of B2B operations experience, hands-on technical execution, and a framework that drives adoption past 70%.
    </p>

    <div class="flex flex-wrap gap-4 items-center">
      <a
        href={calendlyUrl}
        class="bg-accent hover:bg-accent-deep text-white px-7 py-4 rounded-[2px] font-medium transition-all hover:-translate-y-px inline-flex items-center gap-2"
      >
        Schedule a consultation →
      </a>
      <a
        href="/contact/"
        class="text-ink hover:text-accent border-b border-ink hover:border-accent px-6 py-4 font-medium transition-colors"
      >
        Send a message
      </a>
      <span class="font-mono text-xs uppercase tracking-widest text-ink-subtle">
        ~ 20 min · no pitch deck
      </span>
    </div>
  </header>

  <footer class="border-t border-rule px-6 md:px-12 py-10 max-w-6xl mx-auto font-mono text-xs uppercase tracking-widest text-ink-subtle">
    <div class="flex justify-between flex-wrap gap-4">
      <div>ronankeane.com · phase 2 scaffold</div>
      <div>Geist / Geist Mono · burnt orange #C2410C</div>
    </div>
  </footer>
</BaseLayout>
