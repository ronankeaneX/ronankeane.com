---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import SchemaOrg from "../components/SchemaOrg.astro";

const CALENDLY = "https://calendly.com/ronankeane/ai-revenue-acceleration-readiness-discovery-call";
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<BaseLayout
  title="Ronan Keane — AI Strategy & Implementation Consultant"
  description="I help SMB and mid-market companies turn stalled AI initiatives into operational advantage. North Carolina-based. PRIME framework for AI implementation."
>
  <Fragment slot="head">
    <SchemaOrg
      url={canonical}
      title="Ronan Keane — AI Strategy & Implementation Consultant"
      description="I help SMB and mid-market companies turn stalled AI initiatives into operational advantage. North Carolina-based. PRIME framework for AI implementation."
      schemaTypes={["Person", "ProfessionalService"]}
    />
  </Fragment>

  <Nav />

  <header class="px-6 md:px-12 py-24 md:py-32 max-w-6xl mx-auto">
    <p class="font-mono text-xs uppercase tracking-widest text-accent mb-6 inline-flex items-center gap-2">
      <span class="w-6 h-px bg-accent"></span>
      AI Strategy &amp; Implementation
    </p>

    <h1 class="font-display text-5xl md:text-7xl lg:text-[5.5rem] font-semibold leading-[1.02] tracking-tight max-w-[18ch] mb-8">
      Turning stalled AI initiatives into <span class="text-accent">operational advantage.</span>
    </h1>

    <p class="text-lg md:text-xl text-ink-muted max-w-[56ch] mb-10 leading-relaxed">
      I help SMB and mid-market companies move from AI research to AI implementation. Twenty years of B2B operations experience, hands-on technical execution, and a framework that drives adoption past 70%.
    </p>

    <div class="flex flex-wrap gap-4 items-center">
      <a
        href={CALENDLY}
        class="bg-accent hover:bg-accent-deep text-white px-7 py-4 rounded-[2px] font-medium transition-all hover:-translate-y-px inline-flex items-center gap-2"
      >
        Schedule a consultation →
      </a>
      <a
        href="/contact/"
        class="text-ink hover:text-accent border-b border-ink hover:border-accent px-6 py-4 font-medium transition-colors"
      >
        Send a message
      </a>
      <span class="font-mono text-xs uppercase tracking-widest text-ink-subtle">
        ~ 20 min · no pitch deck
      </span>
    </div>
  </header>

  <Footer />
</BaseLayout>
