---
import { getCollection, render } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";
import SchemaOrg from "../../components/SchemaOrg.astro";

const CALENDLY = "https://calendly.com/ronankeane/ai-revenue-acceleration-readiness-discovery-call";

export async function getStaticPaths() {
  const entries = await getCollection("topics", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  );
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const {
  title, description, related_topics, related_services,
  schema_type, faq, publishDate, lastUpdated, noindex,
} = entry.data;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const updated = lastUpdated instanceof Date
  ? lastUpdated.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })
  : String(lastUpdated).slice(0, 10);
---

<PageLayout
  title={`${title} — Ronan Keane`}
  description={description}
  noindex={noindex}
  publishDate={publishDate instanceof Date ? publishDate : new Date(String(publishDate))}
  lastUpdated={lastUpdated instanceof Date ? lastUpdated : new Date(String(lastUpdated))}
>
  <SchemaOrg
    slot="head"
    url={canonical}
    title={`${title} — Ronan Keane`}
    description={description}
    schemaTypes={schema_type}
    publishDate={publishDate instanceof Date ? publishDate : new Date(String(publishDate))}
    lastUpdated={lastUpdated instanceof Date ? lastUpdated : new Date(String(lastUpdated))}
    faqItems={faq}
    breadcrumbs={[{ name: title, url: canonical }]}
  />

  <article class="max-w-3xl mx-auto px-6 md:px-12 py-16 md:py-24">

    <!-- Header -->
    <header class="mb-12">
      <h1 class="font-display text-4xl md:text-5xl font-semibold leading-tight tracking-tight text-ink mb-6">
        {title}
      </h1>
      <p class="text-lg text-ink-muted leading-relaxed max-w-[58ch]">{description}</p>
    </header>

    <!-- Body -->
    <div class="prose-content">
      <Content />
    </div>

    <!-- Related topics -->
    {related_topics && related_topics.length > 0 && (
      <aside class="border-t border-rule mt-16 pt-8">
        <p class="font-mono text-xs uppercase tracking-widest text-ink-subtle mb-4">Related topics</p>
        <ul class="flex flex-wrap gap-3">
          {related_topics.map((slug) => (
            <li>
              <a href={`/topics/${slug}/`} class="font-mono text-xs uppercase tracking-widest border border-rule px-3 py-2 rounded-[2px] text-ink-muted hover:border-accent hover:text-accent transition-colors">
                {slug.replace(/-/g, " ")}
              </a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    <!-- Related services -->
    {related_services && related_services.length > 0 && (
      <aside class="border-t border-rule mt-8 pt-8">
        <p class="font-mono text-xs uppercase tracking-widest text-ink-subtle mb-4">Related services</p>
        <ul class="flex flex-wrap gap-3">
          {related_services.map((slug) => (
            <li>
              <a href={`/services/${slug}/`} class="font-mono text-xs uppercase tracking-widest border border-rule px-3 py-2 rounded-[2px] text-ink-muted hover:border-accent hover:text-accent transition-colors">
                {slug.replace(/-/g, " ")}
              </a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    <!-- CTA -->
    <section class="bg-bg-alt border border-rule rounded-[2px] px-8 py-10 mt-16">
      <p class="font-mono text-xs uppercase tracking-widest text-accent mb-3">/next step</p>
      <h2 class="font-display text-2xl font-semibold text-ink mb-3">Want to go deeper?</h2>
      <p class="text-ink-muted mb-6 max-w-[52ch]">
        Schedule a 20-minute discovery call to talk through how this applies to your business specifically.
      </p>
      <div class="flex flex-wrap gap-4 items-center">
        <a
          href={CALENDLY}
          class="bg-accent hover:bg-accent-deep text-white px-6 py-3 rounded-[2px] font-medium transition-colors inline-flex items-center gap-2"
        >
          Schedule a consultation →
        </a>
        <a href="/contact/" class="text-ink hover:text-accent border-b border-ink hover:border-accent px-2 py-3 font-medium transition-colors">
          Send a message
        </a>
      </div>
    </section>

    <!-- Datestamp -->
    <p class="font-mono text-xs text-ink-subtle mt-8">Last updated: {updated}</p>

  </article>
</PageLayout>
